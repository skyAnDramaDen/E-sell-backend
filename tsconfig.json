    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",

    "verbatimModuleSyntax": false,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}

