              "})",
              "",
              "pm.test(\"Expect message to be User email or password is missing from login validator\", function() {",
              "    const json_data = pm.response.json();",
              "    pm.expect(json_data.message).to.be.eql(\"User email or password is missing from login validator\");",
              "})",
              "",
              "pm.test(\"Expect token to be undefined\", function() {",
              "    const json_data = pm.response.json();",
              "    pm.expect(json_data.token).to.be.undefined;",
